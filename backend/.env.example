# Copy this file to .env and fill in your Cloudinary credentials.

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=portfolio_ib

# Required for uploads/deletes in production.
ADMIN_UPLOAD_TOKEN=replace_with_a_long_random_token

# Comma-separated allowed browser origins. Leave empty for same-origin production.
CORS_ORIGINS=http://localhost:5173,http://localhost:5000

# Max upload size in MB.
MAX_UPLOAD_MB=100

# Cloudinary upload tuning.
CLOUDINARY_UPLOAD_TIMEOUT_MS=300000
CLOUDINARY_LARGE_UPLOAD_THRESHOLD_BYTES=20971520
CLOUDINARY_CHUNK_SIZE=6000000

PORT=5000
